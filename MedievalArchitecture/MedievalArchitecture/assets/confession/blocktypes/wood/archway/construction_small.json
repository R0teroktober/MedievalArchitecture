{
	"enabled": true,
	"code": "construction_small",
	"maxStackSize": 64,
	"blockmaterial": "Wood",
	"resistance": 1,
	"renderPass": "OpaqueNoCull",
	"facecullmode": "nevercull",
	"lightabsorption": 0,
	"sideopaque": {"all": false},
	"sideao": {"all": true},
	"sidesolid": {"all":  false},
	"entityClass": "BlockEntityConstructable",
	"variantgroups": [{"code": "side","loadFromProperties": "abstract/horizontalorientation"}],
	"attributes": {
		"handbook": {"groupBy": [ "construction_small-*" ],
								"excludeByType": {"west": true, "east": true, "south": true},
								"extraSections": [{"title": "confession:construction-drop-help-title", "text": "confession:construction-drop-help-text"}]
		}
	},
	"entityBehaviors": [ { "name": "AttributeRenderingLibrary.ShapeTexturesFromAttributes" } ],
	"behaviors": [
		{ "name": "BlockBehaviorSmallArchwayConstruction", "properties": { "blockCodeBaseString": "confession:arch_small", "intMultiplicator": 1}},
		{ "name": "AttributeRenderingLibrary.HorizontalOrientable", "properties":{"dropBlockFace": "north"} },
		{ "name": "AttributeRenderingLibrary.BlockShapeTexturesFromAttributes",
			"properties": {
				"name": {
					"state-*": ["confession:block-construction_small-name1", "confession:{state}","confession:block-construction_small-name2"],
					"*": [ "confession:block-debug-noname" ]
				},
				"description":  {
					"rock-*::style-*": ["confession:block-arch_small-description1", "rock-{rock}","confession:block-arch_small-description2","confession:{style}", "confession:block-linebreak"],
					"*": ["confession:block-debug-nodescription"]
				},
				"textures": {
					"rock-none": {
						"rim": { "base": "game:block/transparent" },
						"plaster": { "base": "game:block/transparent" },
						"gravel": {"base": "game:block/transparent"}
						},
					"state-*::rock-*": {
						"rim": {"base": "game:block/stone/rock/{rock}1","overlays": [ "game:block/overlay/crackedcobblestone1" ]},
						"gravel": {"base": "game:block/stone/agedbrick/{rock}1"},
						"plaster": {"base": "game:block/stone/rock/{rock}1","blendedOverlays": [{"base": "game:block/clay/fireclay","blendMode": "Lighten"}]}
						}
				},
				"shape": {
					"state-*::style-*": { "base": "confession:block/wood/construction-s-{state}-{style}", "rotateYByType": { "*-east": 90, "*-south": 180, "*-west": 270 } }
					//"state-*::style-*": { "base": "confession:block/wood/construction-s-{style}", "rotateYByType": { "*-east": 90, "*-south": 180, "*-west": 270 } }
					//"style-C": { "base": "confession:block/stone/construction-s-c", "overlays": [ { "base": "block/stone/arch-s-c", "rotateYByType": { "*-we": 90 } }] },
					//"style-D": { "base": "confession:block/stone/construction-s-d", "overlays": [ { "base": "block/stone/arch-s-d", "rotateYByType": { "*-we": 90 } }] }
				}
			}
		}
	],
	"shape": { "base": "game:block/basic/invisible" },
	"textures": { 
		"rim": { "base": "game:block/transparent" },
		"plaster": { "base": "game:block/transparent" },
		"gravel": { "base": "game:block/transparent" },
		"metal": { "base": "game:block/metal/sheet-plain/iron1" }, 
		"wood": { "base": "game:block/wood/debarked/aged"},
    "bamboo": { "base": "game:block/plant/bamboo/stem-brown" },
    "wooven": { "base": "game:block/plant/bamboo/bamboowoven" },
		"planks": { "base": "game:block/wood/planks/generic" }
	},
	"collisionBox": { "x1": 0, "y1": 0.5, "z1": 0, "x2": 1, "y2": 1, "z2": 1 },
	"creativeinventoryStacksByType": {
			"*-north": [
				{
					"tabs": ["confession" ],
					"stacks": [ 
					{ "type": "block", "code": "construction_small-north", "attributes": { "types": {"style":  "b", "rock":  "none", "state": "0" } } },
					{ "type": "block", "code": "construction_small-north", "attributes": { "types": {"style":  "a", "rock":  "none", "state": "0" } } },
					{ "type": "block", "code": "construction_small-north", "attributes": { "types": {"style":  "c", "rock":  "none", "state": "0" } } },
					//{ "type": "block", "code": "construction_small-north", "attributes": { "types": {"style":  "d", "rock":  "none", "state": "0" } } },

					]
				}
			]
		}

